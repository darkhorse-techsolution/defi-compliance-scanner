# Copy this file to .env and fill in any API keys you want to use.
# All keys are OPTIONAL - the scanner runs end-to-end with none of them,
# it just upgrades individual layers as you add them.

# --- Etherscan API key (optional) -----------------------------------------
# When set, the scanner reads chain data from the Etherscan V2 unified API.
# When not set, the scanner falls back to the free Blockscout public API
# (https://eth.blockscout.com) which works without any signup. Get a free
# Etherscan key at https://etherscan.io/myapikey for higher rate limits.
ETHERSCAN_API_KEY=

# --- Anthropic API key (optional) -----------------------------------------
# When set, compliance narratives are generated by the Claude API (the
# scanner uses claude-haiku-4-5 by default because the prompt is small
# and latency matters). When not set, the scanner falls back to a
# deterministic rules-based template that produces the exact same
# report shape. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Public RPC override (optional) ---------------------------------------
# Used for live ETH balance lookups. Defaults to a free public node.
# PUBLIC_RPC_URL=https://ethereum-rpc.publicnode.com

# --- Server config --------------------------------------------------------
HOST=0.0.0.0
PORT=8000
